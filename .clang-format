# Set the language to C++ (works for C/C++ projects)
Language: Cpp

# Set the desired column limit (80 is the standard default)
ColumnLimit: 120

# Break string literals according to ColumnLimit.
BreakStringLiterals: true

PointerAlignment: Left

# --- Function Brace and Body Formatting ---

# Crucial Setting for Braces: Ensures the opening brace of a function is on a new line
BreakBeforeBraces: Custom
BraceWrapping:
  AfterNamespace: true
  AfterClass: true
  AfterFunction: true
  AfterControlStatement: true
  BeforeElse: true
  BeforeCatch: true
  BeforeWhile: true

# Crucial Setting for Short Functions: Never allows short functions to be formatted
# on a single line (which includes having the braces on the same line).
AllowShortFunctionsOnASingleLine: None # Use 'None' to force multi-line formatting

# Crucial Setting for Indentation:
IndentWidth: 2
NamespaceIndentation: All

# --- Function Parameter Formatting ---

# Prevents parameters from being 'packed' together
BinPackParameters: false

# Forces each parameter onto a new, indented line
AllowAllParametersOfDeclarationOnNextLine: false

# --- Return Type Formatting ---

# Prevents a line break after the return type
AlwaysBreakAfterReturnType: None

# Applies a high cost (penalty) to putting the return type on its own line.
PenaltyReturnTypeOnItsOwnLine: 1000

# --- Other common settings ---

AlignTrailingComments: true
AlignAfterOpenBracket: AlwaysBreak
SpaceBeforeParens: ControlStatements